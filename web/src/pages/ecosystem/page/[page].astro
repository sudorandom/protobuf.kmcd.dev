---
import Layout from "../../../layouts/Layout.astro";
import Ecosystem from "../../../react-pages/Ecosystem";
import ecosystemData from "../../../data/ecosystem.json";

export function getStaticPaths() {
  const pageSize = 12;
  const totalPages = Math.ceil(
    (ecosystemData.projects || []).length / pageSize,
  );

  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, index) => {
    const page = index + 2;
    return {
      params: { page: page.toString() },
      props: { page },
    };
  });
}

const { page } = Astro.props;
---

<Layout
  title={`The Ecosystem - Page ${page} | Protobuf Visualized`}
  description="Explore the Protocol Buffers ecosystem: tools, plugins, and libraries for code generation, formatting, linting, validation, and serialization."
>
  <script is:inline define:vars={{ page }}>
    const params = new URLSearchParams(window.location.search);
    params.set("page", page.toString());
    window.location.replace(`/ecosystem/?${params.toString()}${window.location.hash}`);
  </script>
  <Ecosystem initialPage={page} client:load />
</Layout>
