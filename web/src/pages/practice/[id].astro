---
import Layout from "../../layouts/Layout.astro";
import { Practice } from "../../react-pages/Practice";

export function getStaticPaths() {
  return [
    { params: { id: "1" } },
    { params: { id: "2" } },
    { params: { id: "3" } },
    { params: { id: "4" } },
    { params: { id: "5" } },
    { params: { id: "6" } },
    { params: { id: "7" } },
    { params: { id: "8" } },
    { params: { id: "conclusion" } },
  ];
}

const { id } = Astro.params;

const titleMap: Record<string, string> = {
  "1": "Exercise 1: Field Numbers",
  "2": "Exercise 2: Naming",
  "3": "Exercise 3: Integer Types",
  "4": "Exercise 4: Repeated Fields",
  "5": "Exercise 5: Reserved Fields",
  "6": "Exercise 6: Field Presence",
  "7": "Exercise 7: Oneof",
  "8": "Exercise 8: Well-Known Types",
  "conclusion": "Practice Complete",
};

const pageTitle = titleMap[id] || `Exercise ${id}`;
---

<Layout
  title={`${pageTitle} | Protobuf Visualized`}
  description="Practice Protocol Buffers by repairing schemas and satisfying descriptor checks."
>
  <Practice activeId={id} client:load />
</Layout>
